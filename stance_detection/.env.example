# API key for your provider
#OPENROUTER_API_KEY=
#OPENAI_API_KEY=
#LOCAL_LLM_API_KEY=

# Provider: openrouter (default), openai, local, mock
#LLM_PROVIDER=openrouter

# Model name (provider-specific)
#LLM_MODEL=openai/gpt-4o-mini

# Optional overrides
#LLM_BASE_URL=
#LLM_TEMPERATURE=0.3
#LLM_MAX_TOKENS=1024
